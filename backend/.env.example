PORT=5000
MONGODB_URI=mongodb://localhost:27017/gem_itasset
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Email Alerts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=it@gemhospital.local
EMAIL_PASS=your_email_password
EMAIL_FROM=GEM Hospital IT <it@gemhospital.local>
ADMIN_EMAIL=itadmin@gemhospital.local

# File Uploads
UPLOAD_DIR=./uploads

# HTTPS (set to true in production)
USE_HTTPS=false
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.cert

# General
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
